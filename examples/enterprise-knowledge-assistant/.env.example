# Copy this file to .env in this directory and fill in your own values.
# .env is gitignored — never commit real keys.
#
# Required by the Anthropic model configured in agents.yaml and
# local_mcp_agents.yaml:
ANTHROPIC_API_KEY=your-anthropic-key-here

# Required only by the full agents.yaml graph (checked by the
# on_engine_start hook and used by Context7). The local MCP approval runner
# does not connect to Context7:
CONTEXT7_API_KEY=your-context7-key-here

# Optional — enables Langfuse tracing if both are set (see docs/ROADMAP.md).
# LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
# LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
